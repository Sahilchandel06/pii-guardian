APP_ENV=development
HOST=0.0.0.0
PORT=8000
UVICORN_RELOAD=true
SSL_CERTFILE=
SSL_KEYFILE=

DATABASE_URL=sqlite:///./pii_guardian.db
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_EXPIRE_HOURS=8
FILE_ENCRYPTION_KEY=
FILE_MASTER_KEY=
ADMIN_REGISTRATION_TOKEN=replace-admin-bootstrap-token
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=120
MAX_UPLOAD_MB=25
ORIGINAL_RETENTION_DAYS=30
STEPUP_REQUIRED_FOR_RAW_DOWNLOAD=true

USE_PRESIDIO=true
USE_LLM=false
USE_LLM_OPEN_SOURCE=false
REQUIRE_AADHAAR_VERHOEFF=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.1
LLM_MODEL=google/flan-t5-small

OCR_LANG=en
OCR_USE_ANGLE_CLS=true
PADDLE_PDX_CACHE_HOME=.paddlex
USE_QR_SCAN=true
